#!/usr/bin/env python3
import logging
import os
import sys
import time
from pathlib import Path

from azure.identity import ClientSecretCredential
from fabric_cicd import FabricWorkspace, publish_all_items, unpublish_all_orphan_items  # 【1-e25b23】【2-10bce0】

ENV_NAME = "dev"


def setup_logging():
    level = os.getenv("LOG_LEVEL", "INFO").upper()
    logging.basicConfig(
        level=getattr(logging, level, logging.INFO),
        format="%(asctime)s %(levelname)s %(message)s",
        handlers=[logging.StreamHandler(sys.stdout)],
    )


def required(name: str) -> str:
    v = os.getenv(name, "").strip()
    if not v:
        raise ValueError(f"Missing required environment variable: {name}")
    return v


def get_workspace_id() -> str:
    # ✅ Uses your variable directly
    return os.getenv("FABRIC_WS_DEV", "").strip()


def get_repo_dir() -> Path:
    # Repo root default: .../cicd/deploy_dev.py -> parents[1] = repo root
    repo_dir = Path(os.getenv("FABRIC_REPO_DIR", Path(__file__).resolve().parents[1])).resolve()
    if not repo_dir.exists():
        raise ValueError(f"Repository directory not found: {repo_dir}")
    return repo_dir


def token_credential() -> ClientSecretCredential:
    return ClientSecretCredential(
        tenant_id=required("AZURE_TENANT_ID"),
        client_id=required("AZURE_CLIENT_ID"),
        client_secret=required("AZURE_CLIENT_SECRET"),
    )


def run_deploy():
    ws_id = get_workspace_id()
    if not ws_id:
        raise ValueError("FABRIC_WS_DEV is empty/missing.")

    repo_dir = get_repo_dir()

    cleanup_orphans = os.getenv("FABRIC_CLEANUP_ORPHANS", "false").lower() == "true"
    items_raw = os.getenv("FABRIC_ITEMS_IN_SCOPE", "").strip()
    items_in_scope = [x.strip() for x in items_raw.split(",") if x.strip()] if items_raw else None
