model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["sales_table","products_table","customers_table"]

annotation PBI_ProTooling = ["WebModelingEdit"]

ref table sales_table
ref table products_table
ref table customers_table

ref cultureInfo en-US

